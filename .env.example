# ──────────────────────────────────────────────────
# VestuAI — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────

# Google Gemini API key (for AI image & text generation)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Node environment
NODE_ENV=development

# App port (default 3000)
PORT=3000

# ──────────────────────────────────────────────────
# PRODUCTION NOTES:
# - Replace the file-based DB (db.json) with PostgreSQL / Supabase
# - Replace plain-text passwordHash with bcrypt hashed passwords
# - Replace in-memory SESSIONS with Redis or JWT
# - Set NODE_ENV=production
# ──────────────────────────────────────────────────
